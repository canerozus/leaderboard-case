{
  "name": "leaderboard-backend",
  "version": "0.1.0",
  "description": "Leaderboard case — backend API + worker",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "build": "tsc -p tsconfig.json",
    "dev:api": "tsx watch src/index.api.ts",
    "dev:worker": "tsx watch src/index.worker.ts",
    "start:api": "node dist/index.api.js",
    "start:worker": "node dist/index.worker.js",
    "test:unit": "vitest run src/",
    "test:integration": "vitest run tests/integration/",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "seed": "tsx seed/seed.ts",
    "seed:traffic": "tsx seed/demo-traffic.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "private": true,
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.2",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "seedrandom": "^3.0.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.2",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@types/seedrandom": "^3.0.8",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.3.0",
    "supertest": "^7.2.2",
    "testcontainers": "^11.14.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
