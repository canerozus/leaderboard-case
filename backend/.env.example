NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Postgres
POSTGRES_URL=postgres://leaderboard:leaderboard@localhost:5432/leaderboard

# Mongo
MONGO_URL=mongodb://localhost:27017/leaderboard

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-locally-at-least-32-characters-long
JWT_EXPIRES_IN=7d
BCRYPT_COST=10

# Rate limiting
TAP_RATE_LIMIT_TTL_SEC=1
