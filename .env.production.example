# infrastructure/.env.production.example
# Copy to infrastructure/.env.production on the EC2 host and fill in real values.
# NEVER commit infrastructure/.env.production. (It is gitignored via the root .gitignore.)

# ── Image registry ──────────────────────────────────────────────────
GHCR_OWNER=your-github-username
IMAGE_TAG=latest

# ── Backend ────────────────────────────────────────────────────────
LOG_LEVEL=info
JWT_SECRET=replace-with-32+-character-random-string-from-openssl-rand-hex-32
JWT_EXPIRES_IN=7d
BCRYPT_COST=10
TAP_RATE_LIMIT_TTL_SEC=1

# ── Postgres ───────────────────────────────────────────────────────
POSTGRES_DB=leaderboard
POSTGRES_USER=leaderboard
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_URL=postgres://leaderboard:replace-with-strong-password@postgres:5432/leaderboard

# ── Mongo ──────────────────────────────────────────────────────────
MONGO_URL=mongodb://mongo:27017/leaderboard

# ── Redis ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Edge (TLS) ─────────────────────────────────────────────────────
# Flip LEADERBOARD_TLS to 1 only after Task 11 has issued the first cert.
LEADERBOARD_TLS=0
LEADERBOARD_DOMAIN=leaderboard.example.com
LETSENCRYPT_EMAIL=ops@example.com
