# ── Env & secrets ───────────────────────────────────────────
# Default rule: ignore everything that looks like an env file.
.env
.env.*
# Exceptions: this is a take-home submission, so .env.development and
# .env.production are committed with stable values. The reviewer can
# `git clone && make full-stack-up` (or `make prod-up`) without a
# "fill in the blanks" detour. In a real production project these would
# stay ignored and secrets would come from Secrets Manager / Vault.
!.env.development
!.env.production
*.pem
*.key
*.crt
secrets/
.secrets

# ── Docker / volumes (local dev data) ───────────────────────
infrastructure/data/
infrastructure/volumes/
infrastructure/certbot/conf/
infrastructure/certbot/www/
*.sqlite
*.sqlite3

# ── Test / CI ───────────────────────────────────────────────
.vitest-cache/
playwright-report/
test-results/

# ── Misc ────────────────────────────────────────────────────
.tmp/
tmp/
*.bak
docs
.playwright-mcp

# Local overrides — always ignored
.env.local
.env.production.local